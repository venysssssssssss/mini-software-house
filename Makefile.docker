.PHONY: help docker-build docker-up docker-up-gpu docker-up-full docker-up-full-gpu docker-down docker-logs docker-shell docker-create docker-test clean

# Docker variables
DOCKER_IMAGE ?= mini-software-house
DOCKER_TAG ?= latest
OLLAMA_PORT ?= 11434
export OLLAMA_PORT
DOCKER_COMPOSE := docker compose -f docker-compose.yml
DOCKER_COMPOSE_GPU := docker compose -f docker-compose.yml -f docker-compose.gpu.yml
DOCKER_IMAGE_FULL := $(DOCKER_IMAGE):$(DOCKER_TAG)

# Colors for output
BLUE := \033[0;34m
GREEN := \033[0;32m
RED := \033[0;31m
NC := \033[0m

help:
	@echo "$(BLUE)Mini Software House - Docker Commands$(NC)"
	@echo ""
	@echo "$(GREEN)Building:$(NC)"
	@echo "  make docker-build        - Build Docker image"
	@echo "  make docker-rebuild      - Rebuild Docker image (no cache)"
	@echo ""
	@echo "$(GREEN)Running:$(NC)"
	@echo "  make docker-up           - Start default services in CPU mode"
	@echo "  make docker-up-gpu       - Start default services with NVIDIA GPU"
	@echo "  make docker-up-full      - Start CPU mode plus db and redis"
	@echo "  make docker-up-full-gpu  - Start GPU mode plus db and redis"
	@echo "  make docker-down         - Stop all services"
	@echo "  make docker-stop         - Stop services gracefully"
	@echo ""
	@echo "$(GREEN)Execution:$(NC)"
	@echo "  make docker-create DESC='Build a REST API' - Create project with streaming"
	@echo "  make docker-shell        - Open interactive shell in container"
	@echo "  make docker-logs         - Stream logs from all services"
	@echo ""
	@echo "$(GREEN)Monitoring:$(NC)"
	@echo "  make docker-status       - Show system status and GPU info"
	@echo "  make docker-gpu          - Show GPU metrics"
	@echo "  make docker-exec         - Execute command in running container"
	@echo ""
	@echo "$(GREEN)Cleanup:$(NC)"
	@echo "  make docker-clean        - Remove containers and volumes"
	@echo "  make docker-prune        - Prune unused Docker resources"

# Building
docker-build:
	@echo "$(BLUE)Building Docker image: $(DOCKER_IMAGE_FULL)$(NC)"
	docker build -t $(DOCKER_IMAGE_FULL) .
	@echo "$(GREEN)✓ Build complete$(NC)"

docker-rebuild:
	@echo "$(BLUE)Rebuilding Docker image (no cache): $(DOCKER_IMAGE_FULL)$(NC)"
	docker build --no-cache -t $(DOCKER_IMAGE_FULL) .
	@echo "$(GREEN)✓ Rebuild complete$(NC)"

# Running services
docker-up:
	@echo "$(BLUE)Starting services in CPU mode...$(NC)"
	$(DOCKER_COMPOSE) up -d
	@echo "$(GREEN)✓ Services started$(NC)"
	@echo ""
	@echo "Services running:"
	@echo "  • Ollama (LLM): http://localhost:$(OLLAMA_PORT)"
	@echo "  • App container: ready for exec/run commands"
	@echo "  • Streamlit (if started manually): http://localhost:8501"
	@echo "  • GPU: disabled in Docker Compose"

docker-up-gpu:
	@echo "$(BLUE)Starting services with NVIDIA GPU...$(NC)"
	$(DOCKER_COMPOSE_GPU) up -d
	@echo "$(GREEN)✓ Services started$(NC)"
	@echo ""
	@echo "Services running:"
	@echo "  • Ollama (LLM): http://localhost:$(OLLAMA_PORT)"
	@echo "  • App container: ready for exec/run commands"
	@echo "  • Streamlit (if started manually): http://localhost:8501"
	@echo "  • GPU: enabled for Ollama"

docker-up-full:
	@echo "$(BLUE)Starting CPU mode with db and redis...$(NC)"
	$(DOCKER_COMPOSE) --profile extras up -d
	@echo "$(GREEN)✓ Services started$(NC)"
	@echo ""
	@echo "Services running:"
	@echo "  • Ollama (LLM): http://localhost:$(OLLAMA_PORT)"
	@echo "  • App container: ready for exec/run commands"
	@echo "  • Streamlit (if started manually): http://localhost:8501"
	@echo "  • PostgreSQL: localhost:5432"
	@echo "  • Redis: localhost:6379"
	@echo "  • GPU: disabled in Docker Compose"

docker-up-full-gpu:
	@echo "$(BLUE)Starting GPU mode with db and redis...$(NC)"
	$(DOCKER_COMPOSE_GPU) --profile extras up -d
	@echo "$(GREEN)✓ Services started$(NC)"
	@echo ""
	@echo "Services running:"
	@echo "  • Ollama (LLM): http://localhost:$(OLLAMA_PORT)"
	@echo "  • App container: ready for exec/run commands"
	@echo "  • Streamlit (if started manually): http://localhost:8501"
	@echo "  • PostgreSQL: localhost:5432"
	@echo "  • Redis: localhost:6379"
	@echo "  • GPU: enabled for Ollama"

docker-down:
	@echo "$(BLUE)Stopping all services...$(NC)"
	$(DOCKER_COMPOSE) down
	@echo "$(GREEN)✓ Services stopped$(NC)"

docker-stop:
	@echo "$(BLUE)Stopping services gracefully...$(NC)"
	$(DOCKER_COMPOSE) stop
	@echo "$(GREEN)✓ Services stopped$(NC)"

# Execution
docker-create:
	@if [ -z "$(DESC)" ]; then \
		echo "$(RED)Error: DESC parameter required$(NC)"; \
		echo "Usage: make docker-create DESC='Your project description'"; \
		exit 1; \
	fi
	@echo "$(BLUE)Creating project with description: $(DESC)$(NC)"
	$(DOCKER_COMPOSE) exec app python -m src.cli create "$(DESC)" --verbose --name="$$(python3 -c 'import re; print(re.sub(r"[^\w-]", "-", "$(DESC)".lower()).replace("_", "-")[:20])')"

docker-shell:
	@echo "$(BLUE)Opening shell in running container...$(NC)"
	$(DOCKER_COMPOSE) exec app /bin/sh

docker-logs:
	@echo "$(BLUE)Streaming logs from all services...$(NC)"
	$(DOCKER_COMPOSE) logs -f

# Monitoring
docker-status:
	@echo "$(BLUE)System Status$(NC)"
	$(DOCKER_COMPOSE) exec app python -m src.cli status

docker-gpu:
	@echo "$(BLUE)GPU Metrics$(NC)"
	$(DOCKER_COMPOSE) exec app python -m src.cli info

docker-exec:
	@if [ -z "$(CMD)" ]; then \
		echo "$(RED)Error: CMD parameter required$(NC)"; \
		echo "Usage: make docker-exec CMD='python -m src.cli status'"; \
		exit 1; \
	fi
	@$(DOCKER_COMPOSE) exec app $(CMD)

# Visualization
docker-ps:
	@echo "$(BLUE)Running containers:$(NC)"
	docker ps --filter "label!=none" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"

docker-images:
	@echo "$(BLUE)Available images:$(NC)"
	docker images | grep mini-software-house

# Cleanup
docker-clean:
	@echo "$(BLUE)Cleaning up Docker resources...$(NC)"
	$(DOCKER_COMPOSE) down -v
	@echo "$(GREEN)✓ Cleanup complete$(NC)"

docker-prune:
	@echo "$(BLUE)Pruning unused Docker resources...$(NC)"
	docker system prune -f
	@echo "$(GREEN)✓ Prune complete$(NC)"

# Testing
docker-test:
	@echo "$(BLUE)Running tests in Docker...$(NC)"
	$(DOCKER_COMPOSE) exec app python -m pytest tests/ -v

# Advanced
docker-rebuild-services:
	@echo "$(BLUE)Rebuilding all services...$(NC)"
	$(DOCKER_COMPOSE) down
	$(DOCKER_COMPOSE) build --no-cache
	$(DOCKER_COMPOSE) up -d
	@echo "$(GREEN)✓ Services rebuilt and started$(NC)"

docker-live-streaming:
	@echo "$(BLUE)Starting live monitoring dashboard...$(NC)"
	$(DOCKER_COMPOSE) exec app python -m streamlit run src/dashboard.py --logger.level=debug

# Help for Docker specific commands
docker-help: help
